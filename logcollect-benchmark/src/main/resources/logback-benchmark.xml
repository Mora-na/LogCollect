<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <!-- Root baseline appender for benchmark: discard everything by default -->
    <appender name="NOP" class="ch.qos.logback.core.helpers.NOPAppender"/>

    <!-- Minimal progress output for benchmark runner only -->
    <appender name="PROGRESS" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Optional file output appender definitions (enabled in with-file-output config file) -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>target/benchmark-output.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>8192</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="FILE"/>
    </appender>

    <!-- ROOT only has NOP; LogCollect appender is auto-registered onto ROOT by framework -->
    <root level="INFO">
        <appender-ref ref="NOP"/>
    </root>

    <!-- Keep only runner progress visible -->
    <logger name="com.logcollect.benchmark.stress.runner" level="INFO" additivity="false">
        <appender-ref ref="PROGRESS"/>
    </logger>

    <!-- Scenario logs must propagate to ROOT so LogCollect appender can receive them -->
    <logger name="com.logcollect.benchmark.stress.scenario" level="INFO" additivity="true">
    </logger>

    <!-- Baseline scenario explicitly bypasses LogCollect and only goes to NOP -->
    <logger name="com.logcollect.benchmark.baseline" level="INFO" additivity="false">
        <appender-ref ref="NOP"/>
    </logger>

    <logger name="com.logcollect.internal" level="WARN" additivity="false">
        <appender-ref ref="NOP"/>
    </logger>
    <logger name="io.github.morana.logcollect.internal" level="WARN" additivity="false">
        <appender-ref ref="NOP"/>
    </logger>

    <logger name="org.springframework" level="WARN"/>
    <logger name="org.apache" level="WARN"/>
</configuration>
