com.logcollect.autoconfigure.LogCollectMetricsAutoConfiguration,\
com.logcollect.autoconfigure.LogCollectHealthAutoConfiguration,\
com.logcollect.autoconfigure.LogCollectManagementAutoConfiguration,\
com.logcollect.autoconfigure.LogCollectTransactionAutoConfiguration
